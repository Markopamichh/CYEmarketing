---
import { cases } from '../data/cases';
---

<section id="casos" class="relative px-6 py-20 md:py-32">
  <span
    class="pointer-events-none absolute right-4 top-8 select-none font-serif text-[7rem] leading-none text-ink/[0.06] md:text-[12rem]"
    data-parallax
    aria-hidden="true">03</span
  >

  <div class="mx-auto max-w-5xl">
    <h2 class="font-serif text-3xl md:text-5xl" data-reveal>
      Casos <em class="text-accent">reales</em>, resultados reales
    </h2>
    <p class="mt-4 max-w-xl text-ink/70" data-reveal>
      Negocios de la zona con los que trabajamos y lo que cambió.
    </p>

    <div class="mt-16 space-y-20 md:space-y-28">
      {
        cases.map((c, i) => (
          <article
            class={`grid items-center gap-8 md:grid-cols-2 md:gap-16 ${i % 2 ? 'md:[&>figure]:order-2' : ''}`}
            data-reveal-group
          >
            <figure data-reveal>
              <div
                class="aspect-[4/3] overflow-hidden rounded-subtle border border-ink/10 bg-accent-soft"
                data-clip-reveal
              >
                {/* REEMPLAZAR: foto real del proyecto (usar astro:assets <Image>) */}
                <div class="flex h-full items-center justify-center font-serif text-3xl text-accent/50">
                  {c.client}
                </div>
              </div>
            </figure>

            <div data-reveal>
              <span class="text-sm uppercase tracking-[0.18em] text-ink/50">{c.category}</span>
              <h3 class="mt-2 font-serif text-2xl md:text-3xl">{c.client}</h3>
              <p class="mt-5 text-ink/70">
                <strong class="font-medium text-ink">El problema.</strong> {c.problem}
              </p>
              <p class="mt-3 text-ink/70">
                <strong class="font-medium text-ink">Qué hicimos.</strong> {c.solution}
              </p>
              <p class="mt-7 border-t border-ink/10 pt-5 font-serif text-4xl text-accent md:text-5xl">
                {c.metricPrefix}<span data-counter={c.metricValue}>0</span>{c.metricSuffix}
                <span class="ml-2 align-middle font-sans text-base text-ink/60">{c.metricLabel}</span>
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
