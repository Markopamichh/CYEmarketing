---
import { INSTAGRAM_URL, WHATSAPP_URL, SITE } from '../data/site';

const links = [
  { href: '#nosotras', label: 'Nosotros' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#casos', label: 'Casos' },
  { href: '#proceso', label: 'Proceso' },
];
---

<header class="fixed inset-x-0 top-4 z-50 px-4 md:top-6">
  <nav
    class="mx-auto flex max-w-4xl items-center justify-between rounded-full border border-ink/10 bg-cream/95 py-3 pl-6 pr-3 shadow-[0_1px_2px_rgba(28,27,24,0.06)]"
    aria-label="Principal"
  >
    <a href="#" class="font-serif text-xl tracking-tight">
      CYE<em class="text-accent">.</em>studio
    </a>

    <ul class="hidden items-center gap-8 text-sm md:flex">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="link-underline text-ink/70 hover:text-ink">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener"
        aria-label={`Instagram de ${SITE.name}`}
        class="text-ink/60 transition-colors hover:text-accent"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.2" cy="6.8" r="0.9" fill="currentColor" stroke="none" />
        </svg>
      </a>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        aria-label={`WhatsApp de ${SITE.name}`}
        class="text-ink/60 transition-colors hover:text-accent"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 3a9 9 0 0 0-7.8 13.5L3 21l4.6-1.2A9 9 0 1 0 12 3Z" />
          <path d="M8.8 9.2c0 3.3 2.7 6 6 6l1.4-1.4-1.9-1.2-1 .7a4.6 4.6 0 0 1-2.6-2.6l.7-1-1.2-1.9L8.8 9.2Z" fill="currentColor" stroke="none" />
        </svg>
      </a>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="btn hidden rounded-full border border-ink px-4 py-2 text-sm hover:border-accent hover:bg-accent hover:text-cream sm:block"
      >
        Hablemos
      </a>
    </div>
  </nav>
</header>
