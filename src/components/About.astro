---
// REEMPLAZAR: nombres, roles y fotos reales de las dos integrantes
const team = [
  {
    name: 'Eitan',
    role: 'Estrategia y contenido',
    photo: '/team/persona-1.jpg',
  },
  {
    name: 'Candela',
    role: 'Diseño y publicidad',
    photo: '/team/persona-2.jpg',
  },
];
---

<section id="nosotras" class="relative px-6 py-20 md:py-32">
  <span
    class="pointer-events-none absolute right-4 top-8 select-none font-serif text-[7rem] leading-none text-ink/[0.06] md:text-[12rem]"
    data-parallax
    aria-hidden="true">01</span
  >

  <div class="mx-auto grid max-w-5xl gap-12 md:grid-cols-2 md:gap-20" data-reveal-group>
    <div data-reveal>
      <h2 class="font-serif text-3xl leading-tight md:text-5xl">
        No somos una agencia.<br />
        Somos <em class="text-accent">Eitan y Candela</em>.
      </h2>
      <p class="mt-6 text-ink/70">
        Detrás de CYE Studio no hay un equipo rotativo ni un community manager
        que nunca viste. Somos nosotros dos: atendemos tu cuenta personalmente,
        conocemos tu negocio, tu zona y a tu clientela, y estamos a un mensaje
        de distancia cuando nos necesitás.
      </p>
      <p class="mt-4 text-ink/70">
        Trabajamos con negocios de Centenario, Neuquén y el Alto Valle, y eso se
        nota: entendemos cómo se vende acá.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-6">
      {
        team.map((person) => (
          <figure data-reveal>
            <div
              class="aspect-[3/4] overflow-hidden rounded-subtle border border-ink/10 bg-accent-soft"
              data-clip-reveal
            >
              {/* Placeholder de foto — reemplazar por <Image> de astro:assets con la foto real */}
              <div class="flex h-full items-center justify-center font-serif text-5xl text-accent/50">
                {person.name[0]}
              </div>
            </div>
            <figcaption class="mt-3">
              <span class="block font-serif text-xl">{person.name}</span>
              <span class="text-sm text-ink/60">{person.role}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
